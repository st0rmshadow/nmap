<Page
    x:Class="Zenmap.Windows.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Padding="16">
        <StackPanel Spacing="12" MaxWidth="640">
            <TextBlock Text="Settings" Style="{ThemeResource TitleTextBlockStyle}" />
            <TextBox x:Name="DefaultTargetBox" Header="Default target" />
            <TextBox x:Name="NmapBinaryBox" Header="Nmap binary" />
            <ComboBox x:Name="DefaultProfileCombo" Header="Default profile" />
            <ComboBox x:Name="StatsEveryCombo" Header="Stats every">
                <ComboBoxItem Content="1s" />
                <ComboBoxItem Content="5s" />
                <ComboBoxItem Content="10s" />
                <ComboBoxItem Content="30s" />
                <ComboBoxItem Content="60s" />
            </ComboBox>
            <ToggleSwitch x:Name="AutoStatsSwitch" Header="Auto add --stats-every" />
            <ToggleSwitch x:Name="AutoVerboseSwitch" Header="Auto add -v" />
            <Button Content="Save Settings" Click="SaveButton_Click" />
        </StackPanel>
    </ScrollViewer>
</Page>
