<Page
    x:Class="Zenmap.Windows.Views.ProfilesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="12" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBox x:Name="FilterBox" Grid.Row="0" PlaceholderText="Filter profiles..." TextChanged="FilterBox_TextChanged" />
        <ListView x:Name="ProfilesList" Grid.Row="1" SelectionChanged="ProfilesList_SelectionChanged" />
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
            <Button Content="Use" Click="UseButton_Click" />
            <Button Content="Add" Click="AddButton_Click" />
            <Button Content="Edit" Click="EditButton_Click" />
            <Button Content="Delete" Click="DeleteButton_Click" />
            <Button Content="Duplicate" Click="DuplicateButton_Click" />
            <Button Content="Import" Click="ImportButton_Click" />
            <Button Content="Export" Click="ExportButton_Click" />
        </StackPanel>
    </Grid>
</Page>
