<Page
    x:Class="Zenmap.Windows.Views.HostsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="16,12" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Hosts" Style="{StaticResource ZenmapSectionTitleStyle}" />
                <TextBlock x:Name="CountText" Style="{StaticResource ZenmapDimTextStyle}" VerticalAlignment="Center" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <Button Content="Show Details" Click="DetailsButton_Click" />
                <Button Content="Copy Address" Click="CopyAddressButton_Click" />
            </StackPanel>
        </Grid>

        <TextBox
            x:Name="FilterBox"
            Grid.Row="1"
            PlaceholderText="Filter results by host, port, state, service, or version"
            TextChanged="FilterBox_TextChanged" />

        <Grid Grid.Row="2" Padding="12,4" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="90" />
                <ColumnDefinition Width="90" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Address" Style="{StaticResource ZenmapDimTextStyle}" FontWeight="SemiBold" />
            <TextBlock Grid.Column="1" Text="Hostname" Style="{StaticResource ZenmapDimTextStyle}" FontWeight="SemiBold" />
            <TextBlock Grid.Column="2" Text="Status" Style="{StaticResource ZenmapDimTextStyle}" FontWeight="SemiBold" />
            <TextBlock Grid.Column="3" Text="Open Ports" Style="{StaticResource ZenmapDimTextStyle}" FontWeight="SemiBold" />
        </Grid>

        <Grid Grid.Row="3">
            <ListView x:Name="HostsList" SelectionChanged="HostsList_SelectionChanged" DoubleTapped="HostsList_DoubleTapped">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnSpacing="12" Padding="4,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="90" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Address}" FontFamily="Consolas" />
                            <TextBlock Grid.Column="1" Text="{Binding Hostname}" />
                            <TextBlock Grid.Column="2" Text="{Binding Status}" />
                            <TextBlock Grid.Column="3" Text="{Binding OpenPortCount}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <TextBlock
                x:Name="EmptyText"
                Text="Run a scan to populate discovered hosts."
                Style="{StaticResource ZenmapDimTextStyle}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="Collapsed" />
        </Grid>
    </Grid>
</Page>
