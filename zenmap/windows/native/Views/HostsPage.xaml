<Page
    x:Class="Zenmap.Windows.Views.HostsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="12" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBox x:Name="FilterBox" Grid.Row="0" PlaceholderText="Filter hosts..." TextChanged="FilterBox_TextChanged" />
        <ListView x:Name="HostsList" Grid.Row="1" SelectionChanged="HostsList_SelectionChanged" DoubleTapped="HostsList_DoubleTapped">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnSpacing="12" Padding="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="80" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Address}" />
                        <TextBlock Grid.Column="1" Text="{Binding Hostname}" />
                        <TextBlock Grid.Column="2" Text="{Binding Status}" />
                        <TextBlock Grid.Column="3" Text="{Binding OpenPortCount}" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
