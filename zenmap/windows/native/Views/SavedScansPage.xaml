<Page
    x:Class="Zenmap.Windows.Views.SavedScansPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="12" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBox x:Name="FilterBox" Grid.Row="0" PlaceholderText="Filter saved scans..." TextChanged="FilterBox_TextChanged" />
        <ListView x:Name="ScansList" Grid.Row="1" SelectionChanged="ScansList_SelectionChanged" />
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
            <Button Content="Load" Click="LoadButton_Click" />
            <Button Content="Open XML" Click="OpenXmlButton_Click" />
            <Button Content="Import XML" Click="ImportXmlButton_Click" />
            <Button Content="Delete" Click="DeleteButton_Click" />
            <Button Content="Clear All" Click="ClearButton_Click" />
        </StackPanel>
        <StackPanel Grid.Row="3" Spacing="8">
            <TextBox x:Name="NotesBox" Header="Notes" />
            <TextBox x:Name="TagsBox" Header="Tags" />
            <Button Content="Save Metadata" Click="SaveMetadataButton_Click" />
        </StackPanel>
    </Grid>
</Page>
