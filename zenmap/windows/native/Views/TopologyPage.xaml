<Page
    x:Class="Zenmap.Windows.Views.TopologyPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="12" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
            <TextBlock x:Name="CountText" VerticalAlignment="Center" />
            <Button Content="Host Details" Click="DetailsButton_Click" />
        </StackPanel>
        <Canvas x:Name="TopologyCanvas" Grid.Row="1" Background="#FF1E1E24" PointerPressed="TopologyCanvas_PointerPressed" />
    </Grid>
</Page>
