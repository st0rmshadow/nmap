<Page
    x:Class="Zenmap.Windows.Views.SavedScansPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="16,12" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Saved Scans" Style="{StaticResource ZenmapSectionTitleStyle}" />
                <TextBlock x:Name="CountText" Style="{StaticResource ZenmapDimTextStyle}" VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock
                x:Name="PathText"
                Style="{StaticResource ZenmapDimTextStyle}"
                FontFamily="Consolas"
                FontSize="12"
                HorizontalAlignment="Right"
                VerticalAlignment="Center" />
        </Grid>

        <TextBox
            x:Name="FilterBox"
            Grid.Row="1"
            PlaceholderText="Filter saved scans by title, command, date, tags, or notes"
            TextChanged="FilterBox_TextChanged" />

        <ListView x:Name="ScansList" Grid.Row="2" SelectionChanged="ScansList_SelectionChanged">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnSpacing="12" Padding="4,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding ScannedAtLocal}" Style="{StaticResource ZenmapDimTextStyle}" />
                        <TextBlock Grid.Column="1" Text="{Binding DisplayTitle}" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="2" Text="{Binding HostCount}" />
                        <TextBlock Grid.Column="3" Text="{Binding PortCount}" />
                        <TextBlock Grid.Column="4" Text="{Binding Command}" FontFamily="Consolas" TextTrimming="CharacterEllipsis" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8">
            <Button Content="Load" Style="{ThemeResource AccentButtonStyle}" Click="LoadButton_Click" />
            <Button Content="Open XML" Click="OpenXmlButton_Click" />
            <Button Content="Import XML" Click="ImportXmlButton_Click" />
            <Button Content="Delete" Click="DeleteButton_Click" />
            <Button x:Name="PersistScanButton" Content="Save Scan" Click="PersistScanButton_Click" />
            <Button Content="Clear All" Click="ClearButton_Click" />
        </StackPanel>

        <Border
            Grid.Row="4"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12"
            Margin="0,4,0,0">
            <StackPanel Spacing="8">
                <TextBlock Text="Saved Scan Notes" FontWeight="SemiBold" />
                <TextBox x:Name="NotesBox" Header="Notes" AcceptsReturn="True" MinHeight="70" TextWrapping="Wrap" />
                <TextBox x:Name="TagsBox" Header="Tags" />
                <Button Content="Save Metadata" HorizontalAlignment="Left" Click="SaveMetadataButton_Click" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
