<Page
    x:Class="Zenmap.Windows.Views.OutputPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="12">
        <TextBox
            x:Name="OutputBox"
            AcceptsReturn="True"
            IsReadOnly="True"
            FontFamily="Consolas"
            TextWrapping="Wrap"
            ScrollViewer.VerticalScrollBarVisibility="Auto" />
    </Grid>
</Page>
