<Page
    x:Class="Zenmap.Windows.Views.PlaceholderPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="24">
        <StackPanel Spacing="12" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock x:Name="TitleText" Style="{ThemeResource TitleTextBlockStyle}" HorizontalAlignment="Center" />
            <TextBlock
                Text="This view will be implemented in upcoming Windows native parity work."
                Opacity="0.75"
                TextWrapping="WrapWholeWords"
                HorizontalAlignment="Center"
                MaxWidth="480" />
        </StackPanel>
    </Grid>
</Page>
