<Page
    x:Class="Zenmap.Windows.Views.PortsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="16,12" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Ports" Style="{StaticResource ZenmapSectionTitleStyle}" />
                <TextBlock x:Name="CountText" Style="{StaticResource ZenmapDimTextStyle}" VerticalAlignment="Center" />
            </StackPanel>
            <Button Content="Host Details" HorizontalAlignment="Right" Click="DetailsButton_Click" />
        </Grid>

        <TextBox
            x:Name="FilterBox"
            Grid.Row="1"
            PlaceholderText="Filter results by host, port, state, service, or version"
            TextChanged="FilterBox_TextChanged" />

        <Grid Grid.Row="2" Padding="12,4" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="90" />
                <ColumnDefinition Width="80" />
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Host" Style="{StaticResource ZenmapDimTextStyle}" FontWeight="SemiBold" />
            <TextBlock Grid.Column="1" Text="Port" Style="{StaticResource ZenmapDimTextStyle}" FontWeight="SemiBold" />
            <TextBlock Grid.Column="2" Text="State" Style="{StaticResource ZenmapDimTextStyle}" FontWeight="SemiBold" />
            <TextBlock Grid.Column="3" Text="Service" Style="{StaticResource ZenmapDimTextStyle}" FontWeight="SemiBold" />
            <TextBlock Grid.Column="4" Text="Version" Style="{StaticResource ZenmapDimTextStyle}" FontWeight="SemiBold" />
        </Grid>

        <Grid Grid.Row="3">
            <ListView x:Name="PortsList" DoubleTapped="PortsList_DoubleTapped">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnSpacing="12" Padding="4,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding HostAddress}" FontFamily="Consolas" />
                            <TextBlock Grid.Column="1" FontFamily="Consolas">
                                <Run Text="{Binding PortNumber}" /><Run Text="/" /><Run Text="{Binding ProtocolName}" />
                            </TextBlock>
                            <TextBlock Grid.Column="2" Text="{Binding State}" />
                            <TextBlock Grid.Column="3" Text="{Binding ServiceName}" />
                            <TextBlock Grid.Column="4" Text="{Binding ServiceSummary}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <TextBlock
                x:Name="EmptyText"
                Text="Run a scan to see open and closed ports."
                Style="{StaticResource ZenmapDimTextStyle}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="Collapsed" />
        </Grid>
    </Grid>
</Page>
