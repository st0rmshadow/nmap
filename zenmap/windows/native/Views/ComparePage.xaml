<Page
    x:Class="Zenmap.Windows.Views.ComparePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="16,12" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="Compare" Style="{StaticResource ZenmapSectionTitleStyle}" FontSize="22" />
            <TextBlock
                Text="Diff hosts and ports between two saved scans"
                Style="{StaticResource ZenmapDimTextStyle}" />
        </StackPanel>

        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <ComboBox
                x:Name="BaselineCombo"
                Grid.Column="0"
                Header="Baseline scan"
                HorizontalAlignment="Stretch"
                SelectionChanged="CompareSelectionChanged" />
            <ComboBox
                x:Name="ComparisonCombo"
                Grid.Column="1"
                Header="Comparison scan"
                HorizontalAlignment="Stretch"
                SelectionChanged="CompareSelectionChanged" />
        </Grid>

        <Border
            Grid.Row="2"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="4"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <TextBox
                x:Name="ReportBox"
                AcceptsReturn="True"
                IsReadOnly="True"
                FontFamily="Consolas"
                FontSize="13"
                TextWrapping="Wrap"
                BorderThickness="0"
                Background="Transparent"
                ScrollViewer.VerticalScrollBarVisibility="Auto" />
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8">
            <Button Content="Copy Report" Click="CopyButton_Click" />
            <Button Content="Export Report" Click="ExportButton_Click" />
        </StackPanel>
    </Grid>
</Page>
