<Page
    x:Class="Zenmap.Windows.Views.ScanPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Padding="24">
        <StackPanel Spacing="16" MaxWidth="960">
            <TextBlock Text="Scan" Style="{ThemeResource TitleTextBlockStyle}" />
            <TextBlock
                Text="Native WinUI 3 front end for Nmap. Scan execution and result views will mirror the macOS and Linux native apps."
                TextWrapping="WrapWholeWords"
                Opacity="0.8" />

            <ComboBox x:Name="ProfileCombo" Header="Profile" HorizontalAlignment="Stretch" SelectionChanged="ProfileCombo_SelectionChanged" />
            <TextBox x:Name="TargetBox" Header="Target" PlaceholderText="127.0.0.1 or scanme.nmap.org" />
            <TextBox
                x:Name="ArgumentsBox"
                Header="Arguments"
                AcceptsReturn="True"
                TextWrapping="Wrap"
                Height="120" />

            <TextBlock Text="Command preview" Style="{ThemeResource SubtitleTextBlockStyle}" />
            <TextBlock x:Name="CommandPreview" FontFamily="Consolas" TextWrapping="WrapWholeWords" />

            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button x:Name="StartScanButton" Content="Start Scan" Click="StartScanButton_Click" />
                <Button x:Name="StopScanButton" Content="Stop Scan" IsEnabled="False" />
            </StackPanel>

            <InfoBar
                x:Name="PrivilegeInfoBar"
                IsOpen="False"
                Severity="Informational"
                Title="Administrator privileges required"
                Message="Some selected options require elevation through Windows UAC." />
        </StackPanel>
    </ScrollViewer>
</Page>
