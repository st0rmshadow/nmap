<Page
    x:Class="Zenmap.Windows.Views.OutputPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    VerticalAlignment="Stretch"
    HorizontalAlignment="Stretch">
    <!--
      Root uses Auto / Auto / * so the ScrollViewer gets leftover height only.
      Code-behind also clamps OutputBorder.Height from RootGrid.ActualHeight so a
      parent that measures with infinite height cannot make the viewport grow with
      the TextBlock (classic ScrollableHeight=0 / dead wheel / dead auto-scroll).
    -->
    <Grid x:Name="RootGrid" Padding="16,12" RowSpacing="8" SizeChanged="RootGrid_SizeChanged">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid x:Name="HeaderRow" Grid.Row="0">
            <TextBlock Text="Raw Output" Style="{StaticResource ZenmapSectionTitleStyle}" />
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <ToggleSwitch x:Name="AutoScrollSwitch" Header="Auto-scroll" IsOn="True" OffContent="" OnContent="" />
                <Button Content="Find" Click="FindButton_Click" />
                <Button Content="Copy" Click="CopyButton_Click" />
                <Button Content="Clear" Click="ClearButton_Click" />
            </StackPanel>
        </Grid>
        <Grid
            x:Name="FindBar"
            Grid.Row="1"
            ColumnSpacing="8"
            Visibility="Collapsed"
            SizeChanged="RootGrid_SizeChanged">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox
                x:Name="FindBox"
                Grid.Column="0"
                PlaceholderText="Find in output"
                TextChanged="FindBox_TextChanged"
                KeyDown="FindBox_KeyDown" />
            <TextBlock
                x:Name="FindSummary"
                Grid.Column="1"
                VerticalAlignment="Center"
                Style="{StaticResource ZenmapDimTextStyle}"
                MinWidth="90" />
            <Button Grid.Column="2" Content="Previous" Click="FindPrevious_Click" />
            <Button Grid.Column="3" Content="Next" Click="FindNext_Click" />
            <Button Grid.Column="4" Content="Close" Click="FindClose_Click" />
        </Grid>
        <Border
            x:Name="OutputBorder"
            Grid.Row="2"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="4"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            VerticalAlignment="Stretch"
            HorizontalAlignment="Stretch">
            <ScrollViewer
                x:Name="OutputScrollViewer"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollMode="Enabled"
                HorizontalScrollMode="Disabled"
                ZoomMode="Disabled"
                BringIntoViewOnFocusChange="False"
                IsTabStop="True"
                Padding="8,6"
                PointerEntered="OutputScrollViewer_PointerEntered"
                PointerWheelChanged="OutputScrollViewer_PointerWheelChanged">
                <TextBlock
                    x:Name="OutputTextBlock"
                    IsTextSelectionEnabled="True"
                    FontFamily="Consolas"
                    FontSize="13"
                    TextWrapping="Wrap"
                    IsHitTestVisible="True" />
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
