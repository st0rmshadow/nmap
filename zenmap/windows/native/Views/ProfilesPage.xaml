<Page
    x:Class="Zenmap.Windows.Views.ProfilesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="16,12" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="Profiles" Style="{StaticResource ZenmapSectionTitleStyle}" FontSize="22" />
            <TextBlock
                Text="Built-in and custom scan profiles. Custom profiles are stored locally."
                Style="{StaticResource ZenmapDimTextStyle}" />
        </StackPanel>

        <TextBox
            x:Name="FilterBox"
            Grid.Row="1"
            PlaceholderText="Filter profiles"
            TextChanged="FilterBox_TextChanged" />

        <ListView x:Name="ProfilesList" Grid.Row="2" SelectionChanged="ProfilesList_SelectionChanged">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnSpacing="12" Padding="4,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Name}" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="1" Text="{Binding KindLabel}" Style="{StaticResource ZenmapDimTextStyle}" />
                        <TextBlock Grid.Column="2" Text="{Binding Arguments}" FontFamily="Consolas" TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="3" Text="{Binding Description}" Style="{StaticResource ZenmapDimTextStyle}" TextTrimming="CharacterEllipsis" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8">
            <Button Content="Use" Style="{ThemeResource AccentButtonStyle}" Click="UseButton_Click" />
            <Button Content="Add Custom" Click="AddButton_Click" />
            <Button Content="Edit" Click="EditButton_Click" />
            <Button Content="Delete" Click="DeleteButton_Click" />
            <Button Content="Duplicate" Click="DuplicateButton_Click" />
            <Button Content="Import" Click="ImportButton_Click" />
            <Button Content="Export" Click="ExportButton_Click" />
        </StackPanel>
    </Grid>
</Page>
