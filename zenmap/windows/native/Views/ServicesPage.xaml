<Page
    x:Class="Zenmap.Windows.Views.ServicesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="12" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBox x:Name="FilterBox" Grid.Row="0" PlaceholderText="Filter services..." TextChanged="FilterBox_TextChanged" />
        <ListView x:Name="ServicesList" Grid.Row="1" />
    </Grid>
</Page>
