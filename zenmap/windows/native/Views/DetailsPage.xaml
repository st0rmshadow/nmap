<Page
    x:Class="Zenmap.Windows.Views.DetailsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Padding="16,12">
        <StackPanel Spacing="14" MaxWidth="1100">
            <TextBlock Text="Scan Details" Style="{StaticResource ZenmapSectionTitleStyle}" FontSize="22" />

            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource ZenmapMetricCardStyle}">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Hosts" Style="{StaticResource ZenmapDimTextStyle}" FontSize="12" />
                        <TextBlock x:Name="HostsMetric" FontSize="22" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource ZenmapMetricCardStyle}">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Ports" Style="{StaticResource ZenmapDimTextStyle}" FontSize="12" />
                        <TextBlock x:Name="PortsMetric" FontSize="22" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource ZenmapMetricCardStyle}">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Open" Style="{StaticResource ZenmapDimTextStyle}" FontSize="12" />
                        <TextBlock x:Name="OpenMetric" FontSize="22" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Style="{StaticResource ZenmapMetricCardStyle}">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Filtered" Style="{StaticResource ZenmapDimTextStyle}" FontSize="12" />
                        <TextBlock x:Name="FilteredMetric" FontSize="22" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="4" Style="{StaticResource ZenmapMetricCardStyle}">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Closed" Style="{StaticResource ZenmapDimTextStyle}" FontSize="12" />
                        <TextBlock x:Name="ClosedMetric" FontSize="22" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14">
                <StackPanel Spacing="6">
                    <TextBlock Text="Scan Context" FontWeight="SemiBold" />
                    <TextBlock x:Name="StatusLine" Style="{StaticResource ZenmapDimTextStyle}" />
                    <TextBlock x:Name="CommandLine" Style="{StaticResource ZenmapMonoTextStyle}" IsTextSelectionEnabled="True" />
                    <TextBlock x:Name="ExitLine" Style="{StaticResource ZenmapDimTextStyle}" />
                    <TextBlock x:Name="XmlLine" Style="{StaticResource ZenmapMonoTextStyle}" IsTextSelectionEnabled="True" />
                    <TextBlock x:Name="BinaryLine" Style="{StaticResource ZenmapMonoTextStyle}" IsTextSelectionEnabled="True" />
                </StackPanel>
            </Border>

            <Border
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14">
                <StackPanel Spacing="8">
                    <TextBlock Text="Selected Host" FontWeight="SemiBold" />
                    <TextBlock x:Name="HostHeaderText" Style="{StaticResource ZenmapDimTextStyle}" />
                    <ListView x:Name="PortsList" MinHeight="180" MaxHeight="360">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="12" Padding="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" FontFamily="Consolas">
                                        <Run Text="{Binding PortNumber}" /><Run Text="/" /><Run Text="{Binding ProtocolName}" />
                                    </TextBlock>
                                    <TextBlock Grid.Column="1" Text="{Binding State}" />
                                    <TextBlock Grid.Column="2" Text="{Binding ServiceName}" />
                                    <TextBlock Grid.Column="3" Text="{Binding ServiceSummary}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
